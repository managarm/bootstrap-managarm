From a920361fc16af80f5696571d76a792c1492a0bdb Mon Sep 17 00:00:00 2001
From: Dennis Bonke <admin@dennisbonke.com>
Date: Fri, 13 Feb 2026 18:08:38 +0100
Subject: [PATCH] Add Managarm support

---
 include/mount-api-utils.h        | 46 +++++++++++++--
 lib/meson.build                  |  4 +-
 libblkid/src/topology/ioctl.c    |  2 +
 libmount/meson.build             | 35 +++++-------
 libmount/src/hook_mount_legacy.c |  1 +
 libmount/src/hook_subdir.c       |  1 +
 meson.build                      | 96 ++++++++++++++++----------------
 sys-utils/meson.build            | 12 ----
 8 files changed, 111 insertions(+), 86 deletions(-)

diff --git a/include/mount-api-utils.h b/include/mount-api-utils.h
index a916f99..6e62cde 100644
--- a/include/mount-api-utils.h
+++ b/include/mount-api-utils.h
@@ -8,7 +8,9 @@
 #ifdef HAVE_LINUX_MOUNT_H
 #include <linux/mount.h>
 #include <linux/unistd.h>
+#ifndef __managarm__
 #include <sys/syscall.h>
+#endif
 #include <inttypes.h>
 
 /*
@@ -32,7 +34,11 @@
 #if !defined(HAVE_OPEN_TREE) && defined(SYS_open_tree)
 static inline int open_tree(int dfd, const char *filename, unsigned int flags)
 {
+#ifdef __managarm__
+	return ENOSYS;
+#else
 	return syscall(SYS_open_tree, dfd, filename, flags);
+#endif
 }
 #endif
 
@@ -72,8 +78,12 @@ static inline int open_tree(int dfd, const char *filename, unsigned int flags)
 static inline int move_mount(int from_dfd, const char *from_pathname, int to_dfd,
 			     const char *to_pathname, unsigned int flags)
 {
+#ifdef __managarm__
+	return ENOSYS;
+#else
 	return syscall(SYS_move_mount, from_dfd, from_pathname, to_dfd,
 		       to_pathname, flags);
+#endif
 }
 #endif
 
@@ -137,7 +147,11 @@ struct mount_attr {
 static inline int mount_setattr(int dfd, const char *path, unsigned int flags,
 				struct mount_attr *attr, size_t size)
 {
+#ifdef __managarm__
+	return ENOSYS;
+#else
 	return syscall(SYS_mount_setattr, dfd, path, flags, attr, size);
+#endif
 }
 #endif
 
@@ -160,7 +174,11 @@ enum fsconfig_command {
 static inline int fsconfig(int fd, unsigned int cmd, const char *key,
                     const void *value, int aux)
 {
-        return syscall(SYS_fsconfig, fd, cmd, key, value, aux);
+#ifdef __managarm__
+	return ENOSYS;
+#else
+    return syscall(SYS_fsconfig, fd, cmd, key, value, aux);
+#endif
 }
 #endif
 
@@ -171,7 +189,11 @@ static inline int fsconfig(int fd, unsigned int cmd, const char *key,
 #if !defined(HAVE_FSOPEN) && defined(SYS_fsopen)
 static inline int fsopen(const char *fsname, unsigned int flags)
 {
-        return syscall(SYS_fsopen, fsname, flags);
+#ifdef __managarm__
+	return ENOSYS;
+#else
+    return syscall(SYS_fsopen, fsname, flags);
+#endif
 }
 #endif
 
@@ -182,7 +204,11 @@ static inline int fsopen(const char *fsname, unsigned int flags)
 #if !defined(HAVE_FSMOUNT) && defined(SYS_fsmount)
 static inline int fsmount(int fd, unsigned int flags, unsigned int mount_attrs)
 {
-        return syscall(SYS_fsmount, fd, flags, mount_attrs);
+#ifdef __managarm__
+	return ENOSYS;
+#else
+    return syscall(SYS_fsmount, fd, flags, mount_attrs);
+#endif
 }
 #endif
 
@@ -205,7 +231,11 @@ static inline int fsmount(int fd, unsigned int flags, unsigned int mount_attrs)
 #if !defined(HAVE_FSPICK) && defined(SYS_fspick)
 static inline int fspick(int dfd, const char *pathname, unsigned int flags)
 {
-        return syscall(SYS_fspick, dfd, pathname, flags);
+#ifdef __managarm__
+	return ENOSYS;
+#else
+    return syscall(SYS_fspick, dfd, pathname, flags);
+#endif
 }
 #endif
 
@@ -354,6 +384,9 @@ static inline int ul_statmount(uint64_t mnt_id,
 			struct ul_statmount *buf,
 			size_t bufsize, unsigned int flags)
 {
+#ifdef __managarm__
+	return ENOSYS;
+#else
        struct ul_mnt_id_req req = {
 		.size = MNT_ID_REQ_SIZE_VER1,
 		.mnt_id = mnt_id,
@@ -362,6 +395,7 @@ static inline int ul_statmount(uint64_t mnt_id,
        };
 
        return syscall(SYS_statmount, &req, buf, bufsize, flags);
+#endif
 }
 #endif
 
@@ -372,6 +406,9 @@ static inline ssize_t ul_listmount(uint64_t mnt_id,
 			uint64_t list[], size_t num,
 			unsigned int flags)
 {
+#ifdef __managarm__
+	return ENOSYS;
+#else
        struct ul_mnt_id_req req = {
 		.size = MNT_ID_REQ_SIZE_VER1,
 		.mnt_id = mnt_id,
@@ -380,6 +417,7 @@ static inline ssize_t ul_listmount(uint64_t mnt_id,
        };
 
        return syscall(SYS_listmount, &req, list, num, flags);
+#endif
 }
 #endif
 
