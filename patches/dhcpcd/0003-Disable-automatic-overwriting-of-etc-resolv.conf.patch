 src/dhcpcd.conf | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/src/dhcpcd.conf b/src/dhcpcd.conf
index 916e82d..5755895 100644
--- a/src/dhcpcd.conf
+++ b/src/dhcpcd.conf
@@ -46,3 +46,5 @@ require dhcp_server_identifier
