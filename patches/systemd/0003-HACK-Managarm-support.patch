+#ifdef __managarm__
+        return -ENOSYS; /* Capabilities are not supported on Managarm, so just return an empty set. */
+#else
         assert(ret);
 
         struct __user_cap_header_struct hdr = {
@@ -41,9 +44,13 @@ int capability_get(CapabilityQuintet *ret) {
                 .ambient = UINT64_MAX,
