From 82ebbb752fcc41700879743aba841f905f8ec4f8 Mon Sep 17 00:00:00 2001
From: Dennis Bonke <admin@dennisbonke.com>
Date: Mon, 1 Jun 2026 23:45:57 +0200
Subject: [PATCH 1/2] Add Managarm support

---
 lib/ephy-sync-utils.c |  2 +-
 src/meson.build       | 12 +++++++++++-
 2 files changed, 12 insertions(+), 2 deletions(-)

diff --git a/lib/ephy-sync-utils.c b/lib/ephy-sync-utils.c
index 7642c3f..db57d15 100644
--- a/lib/ephy-sync-utils.c
+++ b/lib/ephy-sync-utils.c
@@ -30,7 +30,7 @@
 #include <stdio.h>
 #include <string.h>
 #include <webkit/webkit.h>
-#if defined(__linux__)
+#if defined(__linux__) || defined(__mlibc__)
 #include <sys/random.h>
 #elif defined(__FreeBSD__) || defined(__OpenBSD__)
 #include <unistd.h>
diff --git a/src/meson.build b/src/meson.build
index ee1a025..28689a3 100644
--- a/src/meson.build
+++ b/src/meson.build
@@ -76,6 +76,16 @@ libephymain_sources = [
   enums
 ]
 
+typelibdir = run_command(
+  'sh', '-c', 'printf "%s" "$TYPEDIR"',
+  check : true
+).stdout().strip()
+
+girdir = run_command(
+  'sh', '-c', 'printf "%s" "$GIRDIR"',
+  check : true
+).stdout().strip()
+
 blueprints = custom_target('blueprints',
   input: files(
     'resources/gtk/action-bar.blp',
@@ -117,7 +127,7 @@ blueprints = custom_target('blueprints',
     'resources/gtk/webapp-additional-urls-dialog.blp',
   ),
   output: '.',
-  command: [find_program('blueprint-compiler'), 'batch-compile', '@OUTPUT@', '@CURRENT_SOURCE_DIR@', '@INPUT@'],
+  command: [find_program('blueprint-compiler'), 'batch-compile', '--typelib-path', typelibdir, '--gir-path', girdir, '@OUTPUT@', '@CURRENT_SOURCE_DIR@', '@INPUT@'],
 )
 
 libephymain_deps = [
