From 1c5faddb43e42dd44d4ab770915e1aa4a96f1c49 Mon Sep 17 00:00:00 2001
From: Dennis Bonke <admin@dennisbonke.com>
Date: Thu, 25 Aug 2022 11:46:31 +0200
Subject: [PATCH 1/2] Add Managarm support

Signed-off-by: Dennis Bonke <admin@dennisbonke.com>
---
 gio/gcredentialsprivate.h | 2 +-
 glib/glib-init.c          | 1 +
 glib/glib-unix.c          | 2 +-
 glib/gstrfuncs.c          | 1 +
 gmodule/meson.build       | 3 +++
 meson.build               | 2 +-
 6 files changed, 8 insertions(+), 3 deletions(-)

diff --git a/gio/gcredentialsprivate.h b/gio/gcredentialsprivate.h
index 0310a75..3c2352c 100644
--- a/gio/gcredentialsprivate.h
+++ b/gio/gcredentialsprivate.h
@@ -104,7 +104,7 @@
  */
 #undef G_CREDENTIALS_HAS_PID
 
-#ifdef __linux__
+#if defined(__linux__) || defined(__managarm__)
 #define G_CREDENTIALS_SUPPORTED 1
 #define G_CREDENTIALS_USE_LINUX_UCRED 1
 #define G_CREDENTIALS_NATIVE_TYPE G_CREDENTIALS_TYPE_LINUX_UCRED
diff --git a/glib/glib-init.c b/glib/glib-init.c
index 0d0ee80..f5601ce 100644
--- a/glib/glib-init.c
+++ b/glib/glib-init.c
@@ -31,6 +31,7 @@
 #include "gmem.h"       /* for g_mem_gc_friendly */
 
 #include <string.h>
+#include <strings.h>
 #include <stdlib.h>
 #include <stdio.h>
 #include <ctype.h>
diff --git a/glib/glib-unix.c b/glib/glib-unix.c
index 24a20df..6466ad1 100644
--- a/glib/glib-unix.c
+++ b/glib/glib-unix.c
@@ -952,7 +952,7 @@ char *
 g_unix_fd_query_path (int      fd,
                       GError **error)
 {
-#if defined(__linux__) || defined(__sun) || defined(_AIX) || defined (__CYGWIN__)
+#if defined(__linux__) || defined(__sun) || defined(_AIX) || defined (__CYGWIN__) || defined(__managarm__)
   char *path;
   char *proc_path;
 
diff --git a/glib/gstrfuncs.c b/glib/gstrfuncs.c
index 2f34835..a89cbb9 100644
--- a/glib/gstrfuncs.c
+++ b/glib/gstrfuncs.c
@@ -35,6 +35,7 @@
 #include <stdlib.h>
 #include <locale.h>
 #include <string.h>
+#include <strings.h>
 #include <locale.h>
 #include <errno.h>
 #include <garray.h>
diff --git a/gmodule/meson.build b/gmodule/meson.build
index 5a22631..39ef461 100644
--- a/gmodule/meson.build
+++ b/gmodule/meson.build
@@ -27,6 +27,9 @@ if g_module_impl == 'G_MODULE_IMPL_DL'
   if cc.get_id() == 'msvc' or cc.get_id() == 'clang-cl'
     message('Building for MSVC: assuming that symbols are prefixed with underscore')
     g_module_need_uscore = 1
+  elif host_system == 'managarm'
+    message('Cross-compiling: assuming that symbols aren\'t prefixed with underscore')
+    g_module_need_uscore = 0
   elif meson.can_run_host_binaries()
     rres = cc.run(dlopen_dlsym_test_code,
                   dependencies : libdl_dep,
diff --git a/meson.build b/meson.build
index bb68398..18d2acf 100644
--- a/meson.build
+++ b/meson.build
@@ -500,7 +500,7 @@ statx_code = '''
     return statx (AT_FDCWD, "/", AT_SYMLINK_NOFOLLOW, STATX_BASIC_STATS | STATX_BTIME, &stat_buf);
   }
   '''
-if host_system != 'android' and cc.compiles(statx_code, name : 'statx() test')
+if host_system != 'android' and target_machine.system() != 'managarm' and cc.compiles(statx_code, name : 'statx() test')
   glib_conf.set('HAVE_STATX', 1)
 endif
 
-- 
2.53.0

