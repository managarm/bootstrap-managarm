diff --git a/src/udev/udevd.c b/src/udev/udevd.c
index 70f8ee5..7a0b9be 100644
--- a/src/udev/udevd.c
+++ b/src/udev/udevd.c
@@ -285,70 +285,93 @@ static int parse_argv(int argc, char *argv[], Manager *manager) {
 }
 
 int run_udevd(int argc, char *argv[]) {
+        int helout = open("/dev/helout", O_RDWR);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         _cleanup_(manager_freep) Manager *manager = NULL;
         int fd_ctrl = -EBADF, fd_uevent = -EBADF;
         int r;
 
         log_setup();
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         manager = manager_new();
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         if (!manager)
                 return log_oom();
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         manager_parse_udev_config(manager);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = parse_argv(argc, argv, manager);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         if (r <= 0)
                 return r;
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = proc_cmdline_parse(parse_proc_cmdline_item, manager, PROC_CMDLINE_STRIP_RD_PREFIX);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         if (r < 0)
                 log_warning_errno(r, "Failed to parse kernel command line, ignoring: %m");
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
-        if (arg_debug) {
+        // if (arg_debug) {
                 log_set_target(LOG_TARGET_CONSOLE);
                 log_set_max_level(LOG_DEBUG);
-        }
+        // }
 
         manager_adjust_arguments(manager);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = must_be_root();
         if (r < 0)
                 return r;
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         /* set umask before creating any file/directory */
         umask(022);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = mac_init();
         if (r < 0)
                 return r;
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         /* Make sure we can have plenty fds (for example for pidfds) */
         (void) rlimit_nofile_bump(-1);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = RET_NERRNO(mkdir("/run/udev", 0755));
         if (r < 0 && r != -EEXIST)
                 return log_error_errno(r, "Failed to create /run/udev: %m");
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = listen_fds(&fd_ctrl, &fd_uevent);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         if (r < 0)
                 return log_error_errno(r, "Failed to listen on fds: %m");
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         r = manager_init(manager, fd_ctrl, fd_uevent);
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         if (r < 0)
                 return log_error_errno(r, "Failed to create manager: %m");
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         if (arg_daemonize) {
+                dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
                 pid_t pid;
 
                 log_info("Starting systemd-udevd version " GIT_VERSION);
 
                 /* connect /dev/null to stdin, stdout, stderr */
+                dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
                 if (log_get_max_level() < LOG_DEBUG) {
                         r = make_null_stdio();
                         if (r < 0)
                                 log_warning_errno(r, "Failed to redirect standard streams to /dev/null: %m");
                 }
+                dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
                 pid = fork();
                 if (pid < 0)
@@ -356,10 +379,13 @@ int run_udevd(int argc, char *argv[]) {
                 if (pid > 0)
                         /* parent */
                         return 0;
+                dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
                 /* child */
                 (void) setsid();
+                dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
         }
+        dprintf(helout, "UDEVD: %s:%d\n", __FILE__, __LINE__);
 
         return manager_main(manager);
 }
