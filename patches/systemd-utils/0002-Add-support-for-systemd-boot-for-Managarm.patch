diff --git a/units/runsvr-usbhid.service b/units/runsvr-usbhid.service
new file mode 100644
index 0000000..5a171af
--- /dev/null
+++ b/units/runsvr-usbhid.service
@@ -0,0 +1,26 @@
+[Unit]
+Description=Cringe
+#Documentation=man:weston(1) man:weston.ini(5)
+#Documentation=https://wayland.freedesktop.org/
+
+# Activate using a systemd socket
+#Requires=weston.socket
+#After=weston.socket
+
+# Since we are part of the graphical session, make sure we are started before
+Before=multi-user.target
+
+[Service]
+Type=oneshot
+#TimeoutStartSec=60
+#WatchdogSec=20
+# Defaults to journal
+#StandardOutput=journal
+StandardError=journal
+
+# add a ~/.config/weston.ini and weston will pick-it up
+ExecStart=/usr/bin/runsvr run /usr/lib/managarm/server/input-usbhid.bin
+#Environment="XDG_RUNTIME_DIR=/run"
+
+[Install]
+WantedBy=sysinit.target
